# Database Connection (Used by the App)
DB_URL=jdbc:mysql://<YOUR_EC2_PUBLIC_IP>:3306/ecommerce_db
DB_USER=root
DB_PASS=root

# Database Setup (Used by the MySQL Container)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ecommerce_db

# To use SQLite (local file only):
# DB_URL=jdbc:sqlite:/usr/local/tomcat/mydatabase.db
# DB_USER=
# DB_PASS=
